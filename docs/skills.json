{
  "api": "InsightFlare Analytics API",
  "version": "1.0.0",
  "base_url": "${baseUrl}",
  "github": {
    "repository": "ravelloh/InsightFlare",
    "url": "https://github.com/ravelloh/InsightFlare"
  },
  "description": "Privacy-focused web analytics platform. Query pageviews, visitors, sessions, events, funnels, retention, Core Web Vitals performance metrics, realtime activity, and technology/browser/UTM breakdowns. Manage sites and tracking configuration programmatically.",
  "documentation_url": "/.well-known/openapi.json",
  "openapi_url": "/.well-known/openapi.json",
  "authentication": {
    "type": "bearer",
    "header": "Authorization",
    "format": "Bearer ifk_live_<prefix>.<secret>",
    "required": true,
    "description": "All /api/v1/ endpoints require an API key. If you do not have one, you MUST ask the user to provide their key or generate one from the InsightFlare dashboard under Settings → API Keys. Without a valid key, every request returns 401 Unauthorized.",
    "obtain": {
      "method": "Ask the user",
      "instructions": "Before making any API call, ask the user: 'Do you have an InsightFlare API key? If so, please provide it. If not, you can generate one from the InsightFlare dashboard under Settings → API Keys.' The key format is ifk_live_<prefix>.<secret>.",
      "dashboard_path": "/app/{team-slug}/settings/api-keys"
    },
    "scopes": {
      "site:read": "List and view sites",
      "site:write": "Create, update, and delete sites",
      "site_config:read": "View tracking configuration and script snippets",
      "site_config:write": "Update tracking configuration",
      "analytics:read": "Query all analytics, realtime, and batch data"
    },
    "error_responses": {
      "401": {
        "codes": ["invalid_api_key", "api_key_expired", "api_key_revoked"],
        "action": "Ask the user for a valid key or to generate a new one."
      },
      "403": {
        "codes": ["insufficient_scope"],
        "action": "The key lacks the required scope. Ask the user to create a key with the needed permissions."
      }
    }
  },
  "standard_response_format": {
    "success": {
      "ok": true,
      "requestId": "string — Cloudflare Ray ID for tracing, include this when reporting issues",
      "timestamp": "ISO 8601 string — response generation time",
      "data": "object or array — the response payload"
    },
    "error": {
      "ok": false,
      "requestId": "string",
      "timestamp": "ISO 8601 string",
      "error": {
        "code": "string — machine-readable snake_case code",
        "message": "string — human-readable description"
      }
    }
  },
  "global_parameters": {
    "from": {
      "type": "integer",
      "description": "Start timestamp (Unix ms)"
    },
    "to": {
      "type": "integer",
      "description": "End timestamp (Unix ms)"
    },
    "interval": {
      "type": "string",
      "description": "Time granularity for trend aggregation. Default varies by query.",
      "enum": ["minute", "hour", "day", "week", "month"]
    },
    "limit": {
      "type": "integer",
      "description": "Maximum number of results to return."
    },
    "siteId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique site identifier. Obtain from the list sites endpoint or the dashboard."
    }
  },
  "typical_workflow": [
    "1. Obtain an API key from the user (ask them, or direct them to dashboard → Settings → API Keys).",
    "2. Call GET /api/v1/sites to list available sites and get siteId values.",
    "3. Use the siteId to query analytics: GET /api/v1/sites/{siteId}/analytics/overview?from=...&to=...",
    "4. For time-series data, use the /trend endpoint with an interval parameter.",
    "5. For multiple queries at once, use POST /api/v1/sites/{siteId}/analytics/batch.",
    "6. For team-level summary, use GET /api/v1/team/dashboard."
  ],
  "endpoints": {
    "public_endpoints": [
      {
        "method": "GET",
        "path": "/healthz",
        "description": "Returns service health status. No authentication required."
      },
      {
        "method": "POST",
        "path": "/collect",
        "description": "Ingests a tracking event from the InsightFlare client SDK. Always returns 204."
      }
    ],
    "sites": [
      {
        "method": "GET",
        "path": "/api/v1/sites",
        "description": "Returns all sites accessible by the authenticated API key within its team.",
        "scope": "site:read"
      },
      {
        "method": "POST",
        "path": "/api/v1/sites",
        "description": "Creates a new site within the API key's team.",
        "scope": "site:write",
        "parameters": {
          "name": "string (required) — site display name",
          "domain": "string (required) — site domain",
          "publicEnabled": "boolean (optional) — enable public stats page",
          "publicSlug": "string (optional) — URL slug for public page"
        },
        "example": "POST /api/v1/sites {\"name\": \"My Blog\", \"domain\": \"blog.example.com\"}"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}",
        "description": "Returns a single site by ID.",
        "scope": "site:read"
      },
      {
        "method": "PATCH",
        "path": "/api/v1/sites/{siteId}",
        "description": "Updates site fields. Only provided fields are changed.",
        "scope": "site:write",
        "parameters": {
          "name": "string",
          "domain": "string",
          "publicEnabled": "boolean",
          "publicSlug": "string"
        }
      },
      {
        "method": "DELETE",
        "path": "/api/v1/sites/{siteId}",
        "description": "Permanently deletes a site and all associated data.",
        "scope": "site:write"
      }
    ],
    "site_config": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/config",
        "description": "Returns the tracking script configuration for a site.",
        "scope": "site_config:read"
      },
      {
        "method": "PATCH",
        "path": "/api/v1/sites/{siteId}/config",
        "description": "Updates the tracking script configuration for a site. Only provided fields are changed.",
        "scope": "site_config:write"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/script-snippet",
        "description": "Returns the HTML snippet to embed the tracking script on a website.",
        "scope": "site_config:read",
        "returns": {
          "siteId": "string",
          "src": "string — full URL to tracking script",
          "snippet": "string — HTML script tag"
        }
      }
    ],
    "analytics_overview": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview",
        "description": "Get aggregate metrics: views, sessions, visitors, bounces, bounce rate, average duration.",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms (required)",
          "to": "Unix ms (required)",
          "interval": "minute|hour|day|week|month"
        }
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/trend",
        "description": "Get time-series trend data (views, visitors, sessions, bounces per bucket).",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms (required)",
          "to": "Unix ms (required)",
          "interval": "minute|hour|day|week|month"
        }
      }
    ],
    "analytics_pages": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/pages",
        "description": "Get top pages ranked by views.",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms",
          "to": "Unix ms",
          "limit": "integer"
        }
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/pages-dashboard",
        "description": "Get pages dashboard data with aggregated page metrics.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/page-hash",
        "description": "Get page URL hash fragment distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/page-query",
        "description": "Get page query string distribution.",
        "scope": "analytics:read"
      }
    ],
    "analytics_sources": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/referrers",
        "description": "Get top referrer sources.",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms",
          "to": "Unix ms",
          "limit": "integer"
        }
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/utm-source",
        "description": "Get UTM source breakdown.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/utm-medium",
        "description": "Get UTM medium breakdown.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/utm-campaign",
        "description": "Get UTM campaign breakdown.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/utm-term",
        "description": "Get UTM term breakdown.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/utm-content",
        "description": "Get UTM content breakdown.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/countries",
        "description": "Get visitor distribution by country.",
        "scope": "analytics:read"
      }
    ],
    "analytics_visitors": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/sessions",
        "description": "List sessions with pagination.",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms",
          "to": "Unix ms",
          "page": "integer",
          "pageSize": "integer"
        }
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/session-detail",
        "description": "Get detailed information for a single session.",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms",
          "to": "Unix ms",
          "page": "integer",
          "pageSize": "integer"
        }
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/visitors",
        "description": "List visitors with pagination.",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms",
          "to": "Unix ms",
          "page": "integer",
          "pageSize": "integer"
        }
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/visitor-detail",
        "description": "Get detailed information for a single visitor.",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms",
          "to": "Unix ms",
          "page": "integer",
          "pageSize": "integer"
        }
      }
    ],
    "analytics_events": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/event-types",
        "description": "List all custom event types for a site.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/events-summary",
        "description": "Get custom event summary statistics.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/events-trend",
        "description": "Get custom event time-series trend.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/events-records",
        "description": "List custom event records with pagination.",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms",
          "to": "Unix ms",
          "page": "integer",
          "pageSize": "integer"
        }
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/event-type-field-values",
        "description": "Get distinct field values for a specific event type.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/event-type-detail",
        "description": "Get detailed statistics for a specific event type.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/event-record-detail",
        "description": "Get detailed information for a single event record.",
        "scope": "analytics:read"
      }
    ],
    "analytics_funnels": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/funnels",
        "description": "List saved conversion funnels for a site.",
        "scope": "analytics:read"
      },
      {
        "method": "POST",
        "path": "/api/v1/sites/{siteId}/analytics/funnels/analyze",
        "description": "Runs a funnel analysis without saving the funnel definition.",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms (required, query param)",
          "to": "Unix ms (required, query param)",
          "steps": "array of step objects (required, body)"
        }
      }
    ],
    "analytics_advanced": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/retention",
        "description": "Get user retention cohort analysis.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/performance",
        "description": "Get Core Web Vitals metrics (TTFB, FCP, LCP, CLS, INP).",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/filter-options",
        "description": "Get available filter dimension values for a site (used to populate filter UIs).",
        "scope": "analytics:read"
      }
    ],
    "analytics_technology": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/browser-trend",
        "description": "Get browser usage trends over time.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/browser-engine-trend",
        "description": "Get browser engine trends.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/browser-version-breakdown",
        "description": "Get browser version distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/browser-cross-breakdown",
        "description": "Get browser × OS cross-tabulation.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/browser-radar",
        "description": "Get browser radar chart data (multi-axis browser comparison).",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/referrer-radar",
        "description": "Get referrer radar chart data (multi-axis referrer comparison).",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/referrer-dimension-trend",
        "description": "Get referrer dimension trends over time.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/client-dimension-trend",
        "description": "Get client dimension (browser/OS/device) trends.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/utm-dimension-trend",
        "description": "Get UTM dimension trends over time.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/client-cross-breakdown",
        "description": "Get client dimension cross-tabulation breakdown.",
        "scope": "analytics:read"
      }
    ],
    "overview_tabs": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-page-path",
        "description": "Overview tab: top page paths.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-page-title",
        "description": "Overview tab: top page titles.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-page-hostname",
        "description": "Overview tab: top hostnames.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-page-entry",
        "description": "Overview tab: top entry pages.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-page-exit",
        "description": "Overview tab: top exit pages.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-source-domain",
        "description": "Overview tab: top referrer domains.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-source-link",
        "description": "Overview tab: top referrer links.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-client-browser",
        "description": "Overview tab: browser distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-client-os-version",
        "description": "Overview tab: OS version distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-client-device-type",
        "description": "Overview tab: device type distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-client-language",
        "description": "Overview tab: language distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-client-screen-size",
        "description": "Overview tab: screen size distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-geo-country",
        "description": "Overview tab: country distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-geo-region",
        "description": "Overview tab: region distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-geo-city",
        "description": "Overview tab: city distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-geo-continent",
        "description": "Overview tab: continent distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-geo-timezone",
        "description": "Overview tab: timezone distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-geo-organization",
        "description": "Overview tab: organization/ISP distribution.",
        "scope": "analytics:read"
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/analytics/overview-geo-points",
        "description": "Overview tab: geographic coordinate points for map rendering.",
        "scope": "analytics:read"
      }
    ],
    "realtime": [
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/realtime/snapshot",
        "description": "Returns a snapshot of recent real-time activity for a site.",
        "scope": "analytics:read",
        "returns": {
          "activeNow": "integer — number of currently active visitors",
          "events": "array — recent activity events"
        }
      },
      {
        "method": "GET",
        "path": "/api/v1/sites/{siteId}/realtime/active",
        "description": "Returns the number of visitors currently active on the site.",
        "scope": "analytics:read",
        "returns": {
          "activeNow": "integer — number of currently active visitors"
        }
      }
    ],
    "batch": [
      {
        "method": "POST",
        "path": "/api/v1/sites/{siteId}/analytics/batch",
        "description": "Executes multiple analytics queries in a single request.",
        "scope": "analytics:read",
        "parameters": {
          "queries": "array of objects, each with a queryName field and optional overrides (from, to, interval, etc.)"
        },
        "example": "POST /api/v1/sites/{siteId}/analytics/batch {\"queries\": [{\"queryName\": \"overview\", \"from\": 0, \"to\": 1}, {\"queryName\": \"trend\", \"interval\": \"day\"}]}"
      }
    ],
    "team": [
      {
        "method": "GET",
        "path": "/api/v1/team/dashboard",
        "description": "Returns an aggregated dashboard for the API key's team.",
        "scope": "analytics:read",
        "parameters": {
          "from": "Unix ms (required)",
          "to": "Unix ms (required)",
          "interval": "hour|day|week|month"
        }
      }
    ]
  },
  "implementation_notes": [
    "All timestamps are in Unix milliseconds (not seconds).",
    "The siteId parameter is a UUID. Obtain it from GET /api/v1/sites.",
    "Pagination uses page/pageSize for visitors and sessions endpoints.",
    "The /analytics/{queryName} path supports all query names listed in the endpoints above.",
    "Rate limits are not currently enforced but may be added. Design for graceful 429 handling.",
    "For LLM agents: always ask the user for an API key before making any request. Do not attempt to guess or generate keys."
  ]
}
